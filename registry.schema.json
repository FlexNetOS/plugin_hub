{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FlexNetOS/plugin_hub/registry.schema.json",
  "title": "plugin_hub registry",
  "description": "Catalog of Claude Code plugins and marketplaces. registry.json is the source of truth; scripts/validate.py enforces it. See template_hub/docs/hub-standard.md.",
  "type": "object",
  "required": ["version", "updated", "org", "hub", "plugins"],
  "properties": {
    "schema": { "type": "string" },
    "version": { "type": "string" },
    "updated": { "type": "string" },
    "org": { "type": "string" },
    "hub": { "const": "plugin_hub" },
    "description": { "type": "string" },
    "plugins": { "type": "array", "items": { "$ref": "#/$defs/plugin" } }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "category", "status", "summary", "installSource", "doc"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "displayName": { "type": "string" },
        "category": { "enum": ["marketplace", "plugin"] },
        "status": { "enum": ["stable", "beta", "experimental", "deprecated"] },
        "summary": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "marketplace": { "type": "string" },
        "pluginVersion": { "type": "string" },
        "provides": {
          "type": "object",
          "properties": {
            "skills": { "type": "integer" },
            "commands": { "type": "integer" },
            "hooks": { "type": "integer" },
            "agents": { "type": "integer" },
            "mcpServers": { "type": "integer" }
          }
        },
        "installSource": { "enum": ["git", "git-subdir", "local"], "description": "How the plugin/marketplace is installed." },
        "sourcePath": { "type": "string" },
        "homepage": { "type": "string" },
        "license": { "type": "string", "description": "SPDX id." },
        "forked": { "type": "boolean" },
        "hosting": { "enum": ["peer", "plugin_hub-child", "registry-only"], "description": "peer = first-party workspace member; plugin_hub-child = fork hosted under plugin_hub; registry-only = third-party pointer." },
        "repo": { "type": "string" },
        "workspaceMember": { "type": "string" },
        "subPath": { "type": "string" },
        "pin": { "type": "string" },
        "upstream": { "type": "string" },
        "doc": { "type": "string" },
        "snippet": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
